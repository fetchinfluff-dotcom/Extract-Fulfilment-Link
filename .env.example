# Application
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=ListingForge
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENCRYPTION_KEY=replace-with-at-least-32-random-bytes
LOG_LEVEL=info

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DIRECT_DATABASE_URL=

# Redis / jobs
REDIS_URL=redis://localhost:6379
JOB_CONCURRENCY_EXTRACT=2
JOB_CONCURRENCY_GENERATE=2
JOB_DEFAULT_ATTEMPTS=3

# AI provider
AI_PROVIDER=openai-compatible
AI_BASE_URL=https://connect.tramai.tech/v1
AI_API_KEY=
AI_MODEL_FAST=tramai-go
AI_MODEL_QUALITY=tramai-go
AI_TIMEOUT_MS=120000
AI_MAX_INPUT_TOKENS=
AI_MOCK_MODE=true

# Supplier integrations
CJ_API_BASE_URL=https://developers.cjdropshipping.com
CJ_ACCESS_TOKEN=
CJ_API_KEY=

ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
ALIEXPRESS_ACCESS_TOKEN=
ALIEXPRESS_API_BASE_URL=

QKSOURCE_API_BASE_URL=
QKSOURCE_API_KEY=

# Crawling and browser
ALLOWED_SOURCE_DOMAINS=mock.listingforge.local,aliexpress.com,www.aliexpress.com,cjdropshipping.com,www.cjdropshipping.com,qksource.com,www.qksource.com
MAX_URL_REDIRECTS=3
MAX_FETCH_BYTES=5242880
FETCH_TIMEOUT_MS=30000
BROWSER_JOB_TIMEOUT_MS=90000
BROWSERLESS_WS_URL=
FIRECRAWL_API_KEY=
FIRECRAWL_ENABLED=false

# Storage
MEDIA_BUCKET=product-media
MAX_IMAGE_BYTES=10485760
MAX_VIDEO_BYTES=52428800
SIGNED_URL_TTL_SECONDS=3600

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
BILLING_ENABLED=false
FREE_TRIAL_CREDITS=3

# Email
RESEND_API_KEY=
EMAIL_FROM=

# Monitoring / analytics
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
ANALYTICS_ENABLED=false

# Security / operations
CRON_SECRET=
INTERNAL_WORKER_TOKEN=
RATE_LIMIT_REDIS_PREFIX=listingforge
SOURCE_SNAPSHOT_RETENTION_DAYS=30
TEMP_MEDIA_RETENTION_HOURS=24

# Feature flags
FEATURE_CJ_ADAPTER=true
FEATURE_ALIEXPRESS_ADAPTER=true
FEATURE_QKSOURCE_ADAPTER=true
FEATURE_FIRECRAWL_FALLBACK=false
FEATURE_SHOPIFY_EXPORT=false
FEATURE_BILLING=false
FEATURE_HIGH_RISK_PRODUCTS=false
