    "@types/react-dom": "^19.2.3",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.87.1",
    "bullmq": "^5.66.1",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.8.2",
    "lucide-react": "^0.562.0",
    "next": "^16.1.1",
